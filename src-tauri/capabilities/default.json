{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:path:default",
    "dialog:default",
    "fs:allow-write-text-file",
    "fs:allow-read-text-file",
    "fs:allow-remove",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "Z:\\JHSSHARE\\LRP Monthly Reports\\**"
        },
        {
          "path": "$TEMP/**"
        },
        {
          "path": "$DOWNLOAD/**"
        }
      ]
    },
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "powershell-script",
          "cmd": "powershell",
          "args": [
            "-NoProfile",
            "-ExecutionPolicy",
            "Bypass",
            "-File",
            { "validator": ".*\\\\lrp_submit_\\d+\\.ps1$" }
          ]
        }
      ]
    },
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "mailto:*" }
      ]
    },
    "updater:default"
  ]
}
