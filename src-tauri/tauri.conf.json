{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "In-Depth Report Assistant",
  "version": "1.3.6",
  "identifier": "com.rhunt.lrpreporttool",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../web"
  },
  "app": {
