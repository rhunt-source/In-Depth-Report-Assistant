{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "In-Depth",
  "version": "1.4.1",
  "identifier": "com.rhunt.lrpreporttool",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "In-Depth",
        "width": 800,
        "height": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/rhunt-source/In-Depth-Report-Assistant/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZGREQ4MTNDNDVCN0E0QzIKUldUQ3BMZEZQSUhkYjZaR1RGVFVNYkpCS2FXSmhDMzFPQ2pkbXRPaWJWbTB6dHhFRSs5NEFVN2wK"
    }
  }
}